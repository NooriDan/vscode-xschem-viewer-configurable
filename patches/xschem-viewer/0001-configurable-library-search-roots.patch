+/**
+ * Search roots injected by a host (e.g. the VS Code extension) that knows where the user's
+ * libraries live. Read at fetch time so the host can set them before the viewer boots.
+ *
+ *  - `XSCHEM_EXTRA_LIBRARY_ROOTS`: base URLs tried as `<root>/<path>`, like XSCHEM_LIBRARY_PATH.
+ *  - `XSCHEM_ROOT_MAP`: `{fs, uri}` pairs mapping a filesystem prefix to a fetchable base URL,
+ *    used to honor absolute symbol references (`C {/abs/foo.sym}`) that fall under a known root.
+ *  - `XSCHEM_RESOLVE_DEBUG`: log every resolution attempt.
+ */
+interface IXschemHostGlobals {
+  XSCHEM_EXTRA_LIBRARY_ROOTS?: string[];
+  XSCHEM_ROOT_MAP?: Array<{ fs: string; uri: string }>;
+  XSCHEM_RESOLVE_DEBUG?: boolean;
+}
+
+function hostGlobals(): IXschemHostGlobals {
+  // `window` in the webview; `globalThis` keeps this usable from a non-DOM test harness.
+  return (typeof window !== 'undefined' ? window : globalThis) as unknown as IXschemHostGlobals;
+}
